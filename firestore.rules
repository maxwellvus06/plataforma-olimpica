rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function logado() {
      return request.auth != null;
    }

    function temPerfil() {
      return logado()
        && exists(/databases/$(database)/documents/sistema_usuarios/$(request.auth.uid));
    }

    function perfil() {
      return get(/databases/$(database)/documents/sistema_usuarios/$(request.auth.uid)).data;
    }

    function nivel() {
      return perfil().nivel;
    }

    function ehAdm() {
      return temPerfil() && nivel() == "ADM";
    }

    function ehStaff() {
      return temPerfil() && nivel() == "Staff";
    }

    function ehGestor() {
      return temPerfil() && nivel() == "Gestor";
    }

    function ehEscola() {
      return temPerfil() && nivel() == "Escola";
    }

    function ehMonitor() {
      return temPerfil() && nivel() == "Monitor";
    }

    function ehProfessor() {
      return temPerfil() && nivel() == "Professor/Orientador";
    }

    function ehAluno() {
      return temPerfil() && nivel() == "Aluno";
    }

    function ehEquipePedagogica() {
      return temPerfil()
        && nivel() in [
          "ADM",
          "Staff",
          "Gestor",
          "Escola",
          "Monitor",
          "Professor/Orientador"
        ];
    }

    function usuarioValido() {
      return temPerfil();
    }

    match /sistema_usuarios/{userId} {
      allow read: if usuarioValido();
      allow create, update: if ehAdm()
        || ehStaff()
        || request.auth.uid == userId;
      allow delete: if ehAdm()
        && request.auth.uid != userId;
    }

    match /sistema_layout/{docId} {
      allow read: if true;
      allow write: if ehAdm() || ehStaff();
    }

    match /sistema_debug/{docId} {
      allow read, write: if ehAdm() || ehStaff();
    }

    match /anos/{ano}/sistema_alunos_lookup/{cpfDoc} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if ehAdm() || ehStaff();
    }

    match /anos/{ano}/sistema_listas_suspensas/{docId} {
      allow read: if usuarioValido();
      allow create, update, delete: if ehAdm();
    }

    match /anos/{ano}/sistema_simulados/{docId} {
      allow get: if usuarioValido()
        || resource.data.publico == true;
      allow list: if usuarioValido();
      allow create, update, delete: if ehEquipePedagogica();
    }

    // Registro público mínimo de tentativa.
    // Serve para bloquear nova tentativa mesmo em aba anônima quando o mesmo e-mail/WhatsApp é usado.
    // Não permite listagem pública.
    match /anos/{ano}/sistema_simulados_tentativas_publicas/{docId} {
      allow get: if true;
      allow list: if false;
      allow create: if !logado()
        && !exists(/databases/$(database)/documents/anos/$(ano)/sistema_simulados_tentativas_publicas/$(docId))
        && request.resource.data.publico == true
        && request.resource.data.simuladoId is string
        && request.resource.data.emailNormalizado is string
        && request.resource.data.whatsappNormalizado is string;
      allow read, update, delete: if ehEquipePedagogica();
    }

    match /anos/{ano}/sistema_simulados_envios/{docId} {
      allow read: if ehEquipePedagogica()
        || (
          usuarioValido()
          && resource.data.usuarioId == request.auth.uid
        );

      allow create: if (
          ehAluno()
          && request.resource.data.usuarioId == request.auth.uid
        )
        ||
        (
          !logado()
          && request.resource.data.visitante == true
          && request.resource.data.publico == true
          && request.resource.data.simuladoId is string
          && request.resource.data.nome is string
          && request.resource.data.email is string
        );

      allow update: if ehEquipePedagogica()
        || (
          ehAluno()
          && resource.data.usuarioId == request.auth.uid
          && request.resource.data.usuarioId == request.auth.uid
        );

      allow delete: if ehEquipePedagogica();
    }

    match /anos/{ano}/sistema_simulados_leads/{docId} {
      allow create: if true;
      allow read, update, delete: if ehAdm() || ehStaff() || ehGestor();
    }

    match /anos/{ano}/sistema_questoes/{docId} {
      allow read: if usuarioValido();
      allow create, update, delete: if ehAdm() || ehStaff() || ehMonitor() || ehProfessor();
    }

    match /anos/{ano}/sistema_banco_questoes/{docId} {
      allow read: if usuarioValido();
      allow create, update, delete: if ehAdm() || ehStaff() || ehMonitor() || ehProfessor();
    }

    match /anos/{ano}/{colecao}/{docId} {
      allow read: if usuarioValido();
      allow create, update, delete: if ehEquipePedagogica()
        && colecao in [
          "sistema_cidades",
          "sistema_escolas",
          "sistema_alunos",
          "sistema_olimpiadas",
          "sistema_cronograma",
          "sistema_premiados",
          "sistema_plataforma",
          "sistema_materiais",
          "sistema_aulas"
        ];
    }

    match /anos/{ano}/{colecao}/{docId}/{subcolecao}/{subDocId} {
      allow read: if usuarioValido();
      allow create, update: if usuarioValido()
        && colecao in [
          "sistema_plataforma",
          "sistema_materiais",
          "sistema_aulas",
          "sistema_simulados"
        ];
      allow delete: if ehEquipePedagogica();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
