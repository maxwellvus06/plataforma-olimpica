rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function logado() {
      return request.auth != null;
    }

    // Regra temporária de estabilização: não é pública, exige Firebase Auth.
    // Serve para eliminar erro de permissão enquanto o front-end estabiliza os módulos novos.
    match /sistema_usuarios/{userId} {
      allow read: if logado();
      allow create, update: if logado();
      allow delete: if logado() && request.auth.uid != userId;
    }

    match /sistema_layout/{docId} {
      allow read: if true;
      allow write: if logado();
    }

    match /sistema_debug/{docId} {
      allow read, write: if logado();
    }

    // Todos os dados anuais: cidades, escolas, alunos, resultados, plataforma,
    // aulas, questões, simulados, envios, leads etc.
    match /anos/{ano}/{document=**} {
      allow read, write: if logado();
    }

    // Bloqueia visitantes não autenticados em qualquer outro lugar.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
