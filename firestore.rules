rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function logado() {
      return request.auth != null;
    }

    // Permite consultar um CPF específico para autoinscrição do aluno.
    // Não libera a coleção completa de alunos; libera apenas docs de lookup por CPF.
    match /anos/{ano}/sistema_alunos_lookup/{cpfDoc} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if logado();
    }

    // Layout pode carregar antes do login.
    match /sistema_layout/{docId} {
      allow read: if true;
      allow write: if logado();
    }

    // Todo o restante exige Firebase Auth.
    match /{document=**} {
      allow read, write: if logado();
    }
  }
}
